# Copy this file to `.env` (same directory) and fill in your values.
# `.env` is gitignored so your registry name won't be committed.
#
# Used by build-azure.sh (Azure Container Registry) and
# build-dockerhub.sh (Docker Hub).

# --- Azure Container Registry (build-azure.sh) ---
# The name of your Azure Container Registry (part before .azurecr.io)
ACR_NAME=

# --- Docker Hub (build-dockerhub.sh) ---
# Docker Hub namespace — image will be pushed to $NAME_VENDOR/nginx-php-fpm.
NAME_VENDOR=
# Optional: Docker Hub username used for `docker login`. Defaults to NAME_VENDOR.
# DOCKERHUB_USER=

# --- Shared ---
# Optional: override target architectures for buildx.
# Defaults to linux/amd64,linux/arm64 (multi-arch manifest).
# A CLI argument to the build script overrides this value.
# PLATFORMS=linux/amd64