# Copy this file to `.env` (same directory) and fill in your values.
# `.env` is gitignored so your registry name won't be committed.
#
# Used by build-azure.sh to push to Azure Container Registry.

# The name of your Azure Container Registry (part before .azurecr.io)
ACR_NAME=

# Optional: override target architectures for buildx.
# Defaults to linux/amd64,linux/arm64 (multi-arch manifest).
# A CLI argument to build-azure.sh overrides this value.
# PLATFORMS=linux/amd64